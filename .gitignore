.DS_Store

# Python virtual environment
.venv/

# Generated audio files — too large for Git, sync via Syncthing instead
Vault/Audio/

# Podcast script cache
Vault/Audio/podcast_history.json

# Sensitive documents (sync via Syncthing only)
Vault/Sensitive/

# Secrets and Credentials
.env
*.pem
*.key
*.p12
secrets.json
credentials.json

# CRITICAL: Never accidentally commit your git-crypt key!
brain-key.key
