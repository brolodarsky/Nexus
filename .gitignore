.DS_Store
# User specific VScode workspace file
Nexus.code-workspace
client_secret*.json


# Python virtual environment
.venv/

# ─────────────────────────────────────────────────
# GUI Frontend — build artifacts and dependencies
# ─────────────────────────────────────────────────
gui/node_modules/
gui/.next/
gui/out/


# ─────────────────────────────────────────────────
# Vault Content — local only, never pushed to GitHub
# ─────────────────────────────────────────────────
# Ignore ALL files inside Vault/ at every nesting level.
# Then whitelist only the structural files that should remain tracked.

# Primary rule (catches all depths via **)
Vault/**

# Belt-and-suspenders: explicit depth rules for safety
Vault/*
Vault/*/*
Vault/*/*/*
Vault/*/*/*/*
Vault/*/*/*/*/*

# Un-ignore directories so Git can traverse them for .gitkeep files
!Vault/**/

# Keep the folder skeleton tracked (empty-folder markers)
!Vault/**/.gitkeep

# Keep the Table of Contents — the public cognitive map
!Vault/Table of Contents.md

# ─────────────────────────────────────────────────
# Secrets and Credentials
# ─────────────────────────────────────────────────
.env
*.pem
*.key
*.p12
secrets.json
credentials.json
.secrets/

# CRITICAL: Never accidentally commit your git-crypt key!
brain-key.key

# ChromaDB vector index (generated)
.chroma_db/
.rag_index_manifest.json
.podcast_history.json

# Local query run logs
src/nexus/logs/

# HITL transaction database and runtime state
src/nexus/hitl.db
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Global logs
logs/

__pycache__/
*.pyc
